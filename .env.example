# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Vercel Blob Storage (automatically configured in Vercel)
# BLOB_READ_WRITE_TOKEN=your_blob_token

# OpenAI (optional, uses Vercel AI Gateway by default)
# OPENAI_API_KEY=sk-your_key_here

# Development Supabase Redirect URL (optional)
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/confirm
